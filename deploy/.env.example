# 将此文件复制为服务器上的：
# /root/overseas-purchase/deploy/.env
#
# CI/CD 只会覆盖 jar/dist，不会帮你填写密钥。

DEPLOY_DIR=/root/overseas-purchase/deploy

# MySQL
MYSQL_ROOT_PASSWORD=change_me

# 后端连接（注意：docker-compose 网络内 MySQL 服务名为 mysql）
DB_URL=jdbc:mysql://mysql:3306/overseas_purchase?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=change_me

# JWT（HS512 需要 >= 64 字节密钥，建议用一段足够长的随机字符串）
JWT_SECRET=change_me_change_me_change_me_change_me_change_me_change_me_change_me

# 支付二维码中的入口地址；保留为空，部署时按实际 HTTP/IP 或 HTTPS 域名填写。
PAYMENT_DOMAIN=
PAYMENT_PROVIDER=LEGACY_QR

# 上传目录（容器内路径，与 docker-compose 挂载一致）
FILE_UPLOAD_PATH=/app/uploads/

# 内容审核：规则始终生效；模型不可用且 AI_REQUIRED=true 时进入人工复核。
MODERATION_ENABLED=false
MODERATION_AI_REQUIRED=true
MODERATION_PROVIDER=openai-compatible
MODERATION_BASE_URL=
MODERATION_API_KEY=
MODERATION_MODEL=
MODERATION_TIMEOUT_MS=4000

# Redis 缓存中间件
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
PERFORMANCE_REDIS_ENABLED=true
PERFORMANCE_REDIS_KEY_PREFIX=overseas-purchase

# JVM 运行参数与 GC 日志
JAVA_OPTS=-Xms256m -Xmx512m -XX:+PrintGCDetails -XX:+PrintGCDateStamps -Xloggc:/app/logs/gc.log -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai
