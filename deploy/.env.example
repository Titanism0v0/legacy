# 将此文件复制为服务器上的：
# /root/overseas-purchase/deploy/.env
#
# CI/CD 只会覆盖 jar/dist，不会帮你填写密钥。

DEPLOY_DIR=/root/overseas-purchase/deploy

# MySQL
MYSQL_ROOT_PASSWORD=change_me
MYSQL_USER=root
MYSQL_PASSWORD=change_me

# 后端连接（注意：docker-compose 网络内 MySQL 服务名为 mysql）
DB_URL=jdbc:mysql://mysql:3306/overseas_purchase?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=change_me

# JWT（HS512 需要 >= 64 字节密钥，建议用一段足够长的随机字符串）
JWT_SECRET=change_me_change_me_change_me_change_me_change_me_change_me_change_me

# 支付二维码中的“支付链接”域名；当前不启用 HTTPS 时可填 http://你的公网IP
PAYMENT_DOMAIN=http://8.136.27.235

